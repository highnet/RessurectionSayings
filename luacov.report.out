    -- Debug.lua
    -- Error handling, xpcall-based safe calls, and conditional debug output.
    -- Depends on: RessurectionSayings.lua (Core)

  3 local RS = RessurectionSayings

  3 RS.Debug = {}
  3 local D = RS.Debug

  3 local ERR_PREFIX  = "|cffff4444[RS Error]|r"
  3 local DBG_PREFIX  = "|cffffff00[RS Debug]|r"
  3 local STACK_LINES = 12   -- max lines of stack trace to display

    -- ─────────────────────────────────────────────────────────────────────────────
    -- Internal error handler  (passed to xpcall)
    -- ─────────────────────────────────────────────────────────────────────────────
    local function OnError(err)
  6     local msg   = tostring(err)
  6     local trace = debugstack(2, STACK_LINES, 3)

  6     print(ERR_PREFIX .. " " .. msg)

  6     if RS.db and RS.db.profile and RS.db.profile.debug then
**0         print(DBG_PREFIX .. " Stack trace:")
**0         for line in trace:gmatch("[^\n]+") do
**0             if line:match("%S") then
**0                 print("   " .. line)
                end
            end
        else
 12         print(ERR_PREFIX
  6             .. " Use |cffffff00/rs debug on|r to see the full stack trace next time.")
        end

  6     return msg
    end

    -- ─────────────────────────────────────────────────────────────────────────────
    -- SafeCall  —  wraps any function in xpcall; prints errors automatically.
    -- Returns: ok (bool), result-or-errorMessage
    -- ─────────────────────────────────────────────────────────────────────────────
  3 function D.SafeCall(fn, ...)
  6     if type(fn) ~= "function" then
  2         print(ERR_PREFIX .. " SafeCall: expected function, got " .. type(fn))
  2         return false, nil
        end
  4     return xpcall(fn, OnError, ...)
    end

    -- ─────────────────────────────────────────────────────────────────────────────
    -- Msg  —  prints to chat only when /rs debug on is active
    -- ─────────────────────────────────────────────────────────────────────────────
  3 function D.Msg(msg)
 17     if RS.db and RS.db.profile and RS.db.profile.debug then
  2         print(DBG_PREFIX .. " " .. tostring(msg))
        end
    end

    -- ─────────────────────────────────────────────────────────────────────────────
    -- Assert  —  fires OnError (and returns false) when condition is falsy
    -- ─────────────────────────────────────────────────────────────────────────────
  3 function D.Assert(condition, msg)
  6     if not condition then
  4         OnError(msg or "Assertion failed")
  4         return false
        end
  2     return true
    end

