    -- Chat.lua
    -- Addon print helpers and in-world chat dispatch (SAY / EMOTE / LOCAL).
    -- Depends on: RessurectionSayings.lua (Core), Debug.lua

  3 local RS = RessurectionSayings

  3 RS.Chat = {}
  3 local C = RS.Chat

    -- Colour codes
  3 local CLR_ADDON = "|cff00ccff"   -- cyan
  3 local CLR_RESET = "|r"
  3 local CLR_WARN  = "|cffffff00"   -- yellow
  3 local CLR_ERR   = "|cffff4444"   -- red
  3 local TAG       = CLR_ADDON .. "[RS]" .. CLR_RESET .. " "

    -- ─────────────────────────────────────────────────────────────────────────────
    -- Local print helpers  (never visible to other players)
    -- ─────────────────────────────────────────────────────────────────────────────

    --- Prints a formatted addon message to the local chat frame.
    --- @param msg string
  3 function C.Print(msg)
  7     print(TAG .. tostring(msg))
    end

    --- Printf-style wrapper around C.Print.
    --- @param fmt string
  3 function C.Printf(fmt, ...)
  1     C.Print(fmt:format(...))
    end

    --- Prints a yellow warning to local chat.
    --- @param msg string
  3 function C.Warn(msg)
  1     C.Print(CLR_WARN .. tostring(msg) .. CLR_RESET)
    end

    --- Prints a red error to local chat.
    --- @param msg string
  3 function C.Error(msg)
  3     C.Print(CLR_ERR .. tostring(msg) .. CLR_RESET)
    end

    -- ─────────────────────────────────────────────────────────────────────────────
    -- Channel definitions  (used by Options panel, SlashCommands, and Speak)
    -- ─────────────────────────────────────────────────────────────────────────────
  3 C.CHANNELS = {
  3     { value = "SAY",   label = "/say  (visible to nearby players)" },
  3     { value = "EMOTE", label = "/emote" },
  3     { value = "LOCAL", label = "Local chat frame only" },
  3 }

    -- Fast lookup table built from C.CHANNELS
  3 local VALID_CHANNEL = {}
 12 for _, ch in ipairs(C.CHANNELS) do
  9     VALID_CHANNEL[ch.value] = true
    end

    --- Returns the human-readable label for the given channel value, or nil.
    --- @param value string
    --- @return string|nil
  3 function C.GetChannelLabel(value)
 14     for _, ch in ipairs(C.CHANNELS) do
 12         if ch.value == value then return ch.label end
        end
    end

    -- ─────────────────────────────────────────────────────────────────────────────
    -- Speak  —  sends a saying through the player's configured output channel
    -- ─────────────────────────────────────────────────────────────────────────────

    --- Sends `saying` through the channel stored in RS.db.channel.
    --- Falls back gracefully on invalid channel values or API errors.
    --- @param saying string
  3 function C.Speak(saying)
  9     if type(saying) ~= "string" or saying == "" then
  3         RS.Debug.Msg("Chat.Speak: empty or non-string saying — skipped.")
  3         return
        end

  6     local ch = (RS.db and RS.db.profile and RS.db.profile.channel) or "SAY"

  6     if not VALID_CHANNEL[ch] then
  1         C.Error(("Unknown channel '%s'; reverting to SAY."):format(ch))
  1         if RS.db then RS.db.profile.channel = "SAY" end
  1         ch = "SAY"
        end

  6     if ch == "LOCAL" then
  1         C.Print(saying)
  1         return
        end

        -- Wrap Blizzard's API in pcall — it can fail in some edge cases
        -- (e.g. player is not yet fully in world, or instance restrictions).
  5     local ok, err = pcall(SendChatMessage, saying, ch)
  5     if not ok then
  1         C.Error(("Could not send message [channel=%s]: %s"):format(ch, tostring(err)))
  1         RS.Debug.Msg("Chat.Speak pcall error: " .. tostring(err))
        end
    end

