    -- ─────────────────────────────────────────────────────────────────────────────
    -- Helpers
    -- ─────────────────────────────────────────────────────────────────────────────

    --- Substitutes {name} in a saying template with the given player name.
    --- @param template string
    --- @param name string
    --- @return string
    local function ApplyName(template, name)
  3     return (template:gsub("{name}", name or "someone"))
    end

    --- Private: ensure the DB has an editable copy of classFile's pool.
  3 function S._ensureDBCopy(classFile)
  8     if not RS.db then return end
  8     if not RS.db.profile.classSayings then RS.db.profile.classSayings = {} end
  8     if not RS.db.profile.classSayings[classFile] then
  5         local src = S.CLASS_SAYINGS[classFile] or {}
  5         local copy = {}
 80         for i, s in ipairs(src) do copy[i] = s end
  5         RS.db.profile.classSayings[classFile] = copy
        end
    end

    --- Returns the effective saying pool for a class (DB overrides or built-ins).
    --- Returns the DB copy whenever one exists (even if empty), so that
    --- "user removed everything" is honoured instead of falling back to built-ins.
    --- @param classFile string
    --- @return table
  3 function S.GetClassPool(classFile)
 12     local db = RS.db and RS.db.profile and RS.db.profile.classSayings
 12     if db and db[classFile] ~= nil then
  5         return db[classFile]   -- may be empty {}; caller must handle that
        end
  7     return S.CLASS_SAYINGS[classFile]
    end

    --- Returns the saying at index for a given class.
    --- @param classFile string
    --- @param index number
    --- @return string
  3 function S.GetClassSaying(classFile, index)
  3     local pool = S.GetClassPool(classFile)
  3     return pool and pool[index] or ""
    end

    --- Persists a single saying edit, copying built-in pool into DB on first edit.
    --- Passing an empty/blank string REMOVES that slot and compacts the array.
    --- @param classFile string
    --- @param index number
    --- @param text string
  3 function S.SetClassSaying(classFile, index, text)
  6     if not RS.db then return end
  5     S._ensureDBCopy(classFile)
  5     local pool = RS.db.profile.classSayings[classFile]
  5     text = text:match("^%s*(.-)%s*$")
  5     if text == "" then
  2         if index >= 1 and index <= #pool then
  2             if #pool <= 1 then
  1                 RS.Debug.Msg("Sayings.Remove: refused — must keep at least 1 saying.")
  1                 return
                end
  1             RS.Debug.Msg(("Sayings.Remove [%s][#%d]: '%s'"):format(classFile, index, pool[index]))
  1             table.remove(pool, index)
            end
        else
  3         if #text > 255 then text = text:sub(1, 255) end
  3         pool[index] = text
  3         RS.Debug.Msg(("Sayings.Set [%s][%d]: '%s'"):format(classFile, index, text))
        end
    end

    --- Resets all sayings for a class to built-in defaults.
    --- @param classFile string
  3 function S.ResetClass(classFile)
  3     if RS.db and RS.db.profile and RS.db.profile.classSayings then
  2         RS.db.profile.classSayings[classFile] = nil
        end
  3     RS.Debug.Msg("Sayings.ResetClass: " .. classFile .. " reset to defaults.")
    end

    --- Appends a new saying to the class pool (ensures DB copy exists first).
    --- @param classFile string
    --- @param text string
    --- @return ok boolean, err string|nil
  3 function S.AddClassSaying(classFile, text)
  5     if not RS.db then return false, "DB not ready." end
  4     text = text:match("^%s*(.-)%s*$")
  4     if text == "" then return false, "Saying cannot be empty." end
  2     if #text > 255 then return false, ("Too long (%d chars, max 255)."):format(#text) end
  1     S._ensureDBCopy(classFile)
  1     table.insert(RS.db.profile.classSayings[classFile], text)
  1     local n = #RS.db.profile.classSayings[classFile]
  1     RS.Debug.Msg(("Sayings.Add [%s][#%d]: '%s'"):format(classFile, n, text))
  1     return true, n
    end



    --- Returns a random saying for the given target name and class.
    --- @param name      string|nil
    --- @param classFile string|nil
    --- @return string
  3 function S.GetRandom(name, classFile)
  6     local pool = classFile and S.GetClassPool(classFile)
  6     if not pool or #pool == 0 then return "" end
  3     return ApplyName(pool[math.random(#pool)], name)
    end
